# Public Supabase project URL used by browser and server clients.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anonymous key used by the browser client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key. Never expose this to client code.
SUPABASE_SERVICE_ROLE_KEY=

# Secret bearer token used to authenticate Vercel Cron calls.
CRON_SECRET=

# Supabase auth UUID for the creator account, doma8192.
CREATOR_USER_ID=

# One-time 11-digit seed for the MVP Arthur genesis script.
ARTHUR_MVP_SEED=

# Optional stable Arthur UUID for genesis SQL. Leave blank to generate one.
ARTHUR_MVP_ARTHUR_ID=

# Optional genesis timestamp in milliseconds. Leave blank to use current time.
ARTHUR_MVP_TIMESTAMP_MS=
